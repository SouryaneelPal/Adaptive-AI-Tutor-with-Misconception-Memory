# Copy this file to .env and fill in values for your own machine.
# .env is gitignored on purpose — every teammate's Ollama/Neo4j/DB setup is
# local to their own machine, so there is nothing generic to commit here.
#
# ── Docker Compose ──────────────────────────────────────────────────────────
# When running via `docker compose up`, the connection URLs below are
# AUTOMATICALLY overridden by docker-compose.yml to use Docker service names
# (ollama → http://ollama:11434, neo4j → bolt://neo4j:7687).
# You only need to change the localhost URLs below for local (non-Docker) dev.
# ────────────────────────────────────────────────────────────────────────────

# --- Ollama (LLM backend for all agents) ---
# Local dev: http://localhost:11434
# Docker:    overridden to http://ollama:11434 in docker-compose.yml
OLLAMA_BASE_URL=http://localhost:11434

# Model used by each agent. They can all be the same model, or tuned
# per-agent. Must already be pulled on the Ollama instance above
# (`ollama pull <model>`).
DIAGNOSTIC_AGENT_MODEL=gemma4:31b
HINT_GENERATOR_MODEL=gemma4:31b
ESCALATION_AGENT_MODEL=gemma4:31b
EVALUATOR_AGENT_MODEL=gemma4:31b
TUTOR_PLANNER_MODEL=gemma4:31b

# Embedding model used by the RAG curriculum retriever (backend/rag/).
# Must also be pulled on the Ollama instance above.
EMBED_MODEL=nomic-embed-text

# --- Neo4j (student mastery / misconception graph) ---
# Run Neo4j Community Server locally (no Docker required — just Java 17+):
# https://neo4j.com/deployment-center/ -> Community, ZIP/TAR, extract, then:
#   bin/neo4j-admin dbms set-initial-password <your-password>   # first time only
#   bin/neo4j console                                            # starts it
# Default ports: bolt on 7687 (used by the app), browser UI on 7474.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Conversation history ---
# Defaults to a local SQLite file (zero setup). Point this at a
# postgresql+psycopg2://user:pass@host:port/dbname DSN to use real Postgres
# instead — no code changes required either way.
DATABASE_URL=sqlite:///backend/data/conversations.db
